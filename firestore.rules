rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ======================================================
    // HELPER FUNCTIONS
    // ======================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // ======================================================
    // USER RULES
    // ======================================================
    match /users/{userId} {
      // Users can only read and write their own profile
      allow read, write: if isAuthenticated() && isOwner(userId);

      // Appointments subcollection within users
      match /appointments/{appointmentId} {
        // Users can read/write their own appointments
        allow read, write: if isAuthenticated() && isOwner(userId);
        
        // Clinics need to be able to manage the appointment in the user's collection
        // (e.g., cancellation or no-show updates).
        allow read, update, delete: if isAuthenticated() && 
          (isOwner(userId) || request.auth.uid == resource.data.clinicUid);
          
        // Clinics might need to CREATE an appointment for a user (manual booking or system logic)
        allow create: if isAuthenticated() && 
          (isOwner(userId) || request.auth.uid == request.resource.data.clinicUid);
      }

      // Favorites subcollection
      match /favorites/{favoriteId} {
        // favoriteId is the clinicUid
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
    }

    // ======================================================
    // CLINIC RULES
    // ======================================================
    match /clinics/{clinicId} {
      // Patients must be able to SEARCH and SEE clinic info
      allow read: if isAuthenticated(); 
      
      // Clinic owner has full access
      allow create, delete: if isAuthenticated() && isOwner(clinicId);
      
      // Update rule: allow clinic owner OR allow patients to increment appointment counter
      allow update: if isAuthenticated() && (
        isOwner(clinicId) || 
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['appointments_this_month']) &&
          (
            (resource.data.appointments_this_month == null && request.resource.data.appointments_this_month == 1) ||
            (request.resource.data.appointments_this_month == resource.data.appointments_this_month + 1)
          )
        )
      );

      // Appointments subcollection within clinics
      match /appointments/{appointmentId} {
        // 1. Clinic owner can see and manage ALL appointments
        allow read, write: if isAuthenticated() && isOwner(clinicId);
   
        // 2. Patients can CREATE an appointment if they are the ones booking it
        allow create: if isAuthenticated() && 
          request.resource.data.userUid == request.auth.uid;
   
        // 3. Patients can READ/UPDATE/DELETE their own appointments
        allow read, update, delete: if isAuthenticated() && 
          resource.data.userUid == request.auth.uid;
   
        // 4. Slot Availability check
        // NOTE: For generateSlots to work, patients must be able to list all appointments
        // to check for occupancy. 
        allow list: if isAuthenticated();
      }
    }
    
    // ======================================================
    // REGISTRATION REQUESTS
    // ======================================================
    match /registration_requests/{requestId} {
      allow create: if isAuthenticated();
      allow read, write: if false; // Admin only
    }
  }
}
